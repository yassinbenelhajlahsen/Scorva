generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model games {
  id                            Int      @id @default(autoincrement())
  league                        String
  date                          DateTime @db.Date
  hometeamid                    Int?
  awayteamid                    Int?
  homescore                     Int?
  awayscore                     Int?
  venue                         String?
  broadcast                     String?
  firstqtr                      String?
  secondqtr                     String?
  thirdqtr                      String?
  fourthqtr                     String?
  ot1                           String?
  ot2                           String?
  ot3                           String?
  ot4                           String?
  status                        String?
  season                        String?
  eventid                       Int?     @unique(map: "games_eventid_unique")
  winnerid                      Int?
  ai_summary                    String?
  game_label                    String?
  current_period                Int?
  clock                         String?
  start_time                    String?
  teams_games_awayteamidToteams teams?   @relation("games_awayteamidToteams", fields: [awayteamid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  teams_games_hometeamidToteams teams?   @relation("games_hometeamidToteams", fields: [hometeamid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stats                         stats[]

  @@unique([eventid, league], map: "games_eventid_league_uniq")
  @@index([awayteamid, date])
  @@index([hometeamid, date], map: "games_teamid_date_idx")
  @@index([awayteamid], map: "idx_games_awayteamid")
  @@index([hometeamid], map: "idx_games_hometeamid")
}

model players {
  id                   Int                    @id @default(autoincrement())
  name                 String
  teamid               Int?
  position             String?
  height               String?
  image_url            String?
  jerseynum            Int?
  weight               String?
  dob                  String?
  draftinfo            String?
  league               String
  espn_playerid        Int?
  teams                teams?                 @relation(fields: [teamid], references: [id], onUpdate: NoAction)
  stats                stats[]
  user_favorite_players user_favorite_players[]

  @@unique([espn_playerid, league], map: "players_espn_playerid_league_uniq")
  @@unique([espn_playerid, league], map: "players_espnid_league_unique")
  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_players_name_trgm", type: Gin)
  @@index([teamid])
}

model stats {
  id            Int     @default(autoincrement())
  gameid        Int
  playerid      Int
  points        Int?
  assists       Int?
  rebounds      Int?
  blocks        Int?
  steals        Int?
  fg            String?
  threept       String?
  ft            String?
  turnovers     Int?
  plusminus     Int?
  minutes       Int?
  yds           Int?
  sacks         String?
  td            Int?
  interceptions Int?
  g             Int?
  a             Int?
  saves         Int?
  savepct       String?
  ga            Int?
  toi           String?
  shots         Int?
  sm            Int?
  bs            Int?
  pn            Int?
  pim           Int?
  ht            Int?
  tk            Int?
  gv            Int?
  fouls         Int?
  cmpatt        String?
  games         games   @relation(fields: [gameid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  players       players @relation(fields: [playerid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([gameid, playerid])
  @@unique([gameid, playerid], map: "stats_gameid_playerid_unique")
}

model teams {
  id                            Int                  @id @default(autoincrement())
  name                          String
  shortname                     String?
  league                        String
  location                      String?
  logo_url                      String?
  record                        String?
  espnid                        Int?
  homerecord                    String?
  awayrecord                    String?
  conf                          String?
  games_games_awayteamidToteams games[]              @relation("games_awayteamidToteams")
  games_games_hometeamidToteams games[]              @relation("games_hometeamidToteams")
  players                       players[]
  user_favorite_teams           user_favorite_teams[]

  @@unique([espnid, league], map: "teams_espnid_league_uniq")
  @@unique([espnid, league], map: "teams_espnid_league_unique")
  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_teams_name_trgm", type: Gin)
  @@index([shortname(ops: raw("gin_trgm_ops"))], map: "idx_teams_shortname_trgm", type: Gin)
}

model users {
  id                   String                 @id @db.Uuid
  created_at           DateTime               @default(now())
  email                String?
  first_name           String?
  last_name            String?
  default_league       String?
  favorite_players     user_favorite_players[]
  favorite_teams       user_favorite_teams[]
}

model user_favorite_players {
  user_id    String   @db.Uuid
  player_id  Int
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  players    players  @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@id([user_id, player_id])
}

model user_favorite_teams {
  user_id    String   @db.Uuid
  team_id    Int
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  teams      teams    @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@id([user_id, team_id])
}

