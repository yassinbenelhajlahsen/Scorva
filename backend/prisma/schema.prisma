generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model games {
  id                            Int      @id @default(autoincrement())
  league                        String
  date                          DateTime @db.Date
  hometeamid                    Int?
  awayteamid                    Int?
  homescore                     Int?
  awayscore                     Int?
  venue                         String?
  broadcast                     String?
  firstqtr                      String?
  secondqtr                     String?
  thirdqtr                      String?
  fourthqtr                     String?
  ot1                           String?
  ot2                           String?
  ot3                           String?
  ot4                           String?
  status                        String?
  season                        String?
  eventid                       Int?
  winnerid                      Int?
  ai_summary                    String?
  game_label                    String?
  current_period                Int?
  clock                         String?
  start_time                    String?
  type                          String   @default("regular")
  teams_games_awayteamidToteams teams?            @relation("games_awayteamidToteams", fields: [awayteamid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  teams_games_hometeamidToteams teams?            @relation("games_hometeamidToteams", fields: [hometeamid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stats                         stats[]
  plays                         plays[]
  game_embeddings               game_embeddings?

  @@unique([eventid, league], map: "games_eventid_league_uniq")
  @@index([awayteamid, date])
  @@index([hometeamid, date], map: "games_teamid_date_idx")
  @@index([league, season, date], map: "idx_games_league_season_date")
}

model players {
  id                   Int                    @id @default(autoincrement())
  name                 String
  teamid               Int?
  position             String?
  height               String?
  image_url            String?
  jerseynum            Int?
  weight               String?
  dob                  String?
  draftinfo            String?
  league               String
  espn_playerid        Int?
  popularity           Int                    @default(0)
  status               String?                @db.VarChar(20)
  status_description   String?
  status_updated_at    DateTime?              @db.Timestamptz(6)
  teams                    teams?                    @relation(fields: [teamid], references: [id], onUpdate: NoAction)
  stats                    stats[]
  user_favorite_players    user_favorite_players[]
  aliases                  player_aliases[]
  player_stat_embeddings   player_stat_embeddings[]
  awards                   player_awards[]

  @@unique([espn_playerid, league], map: "players_espnid_league_unique")
  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_players_name_trgm", type: Gin)
  @@index([teamid])
  @@index([popularity(sort: Desc)], map: "idx_players_popularity")
}

model stats {
  id            Int     @default(autoincrement())
  gameid        Int
  playerid      Int
  points        Int?
  assists       Int?
  rebounds      Int?
  blocks        Int?
  steals        Int?
  fg            String?
  threept       String?
  ft            String?
  turnovers     Int?
  plusminus     Int?
  minutes       Int?
  yds           Int?
  sacks         String?
  td            Int?
  interceptions Int?
  g             Int?
  a             Int?
  saves         Int?
  savepct       String?
  ga            Int?
  toi           String?
  shots         Int?
  sm            Int?
  bs            Int?
  pn            Int?
  pim           Int?
  ht            Int?
  tk            Int?
  gv            Int?
  fouls         Int?
  cmpatt        String?
  teamid        Int?
  games         games   @relation(fields: [gameid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  players       players @relation(fields: [playerid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  teams         teams?  @relation(fields: [teamid], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@id([gameid, playerid])
  @@index([playerid])
  @@index([teamid])
}

model teams {
  id                            Int                  @id @default(autoincrement())
  name                          String
  shortname                     String?
  league                        String
  location                      String?
  logo_url                      String?
  record                        String?
  espnid                        Int?
  homerecord                    String?
  awayrecord                    String?
  primary_color                 String?  @db.VarChar(7)
  abbreviation                  String?  @db.VarChar(5)
  conf                          String?
  division                      String?
  games_games_awayteamidToteams games[]              @relation("games_awayteamidToteams")
  games_games_hometeamidToteams games[]              @relation("games_hometeamidToteams")
  players                       players[]
  stats                         stats[]
  plays                         plays[]
  user_favorite_teams           user_favorite_teams[]

  @@unique([espnid, league], map: "teams_espnid_league_unique")
}

model users {
  id                   String                 @id @db.Uuid
  created_at           DateTime               @default(now())
  email                String?
  first_name           String?
  last_name            String?
  default_league       String?
  favorite_players     user_favorite_players[]
  favorite_teams       user_favorite_teams[]
  chat_conversations   chat_conversations[]
}

model chat_conversations {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String          @db.Uuid
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime        @default(now()) @db.Timestamptz(6)
  summary         String?
  summarized_up_to Int            @default(0)
  users           users           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages        chat_messages[]

  @@index([user_id], map: "chat_conversations_user_idx")
}

model chat_messages {
  id              Int                @id @default(autoincrement())
  conversation_id String             @db.Uuid
  role            String
  content         String
  page_context    Json?
  created_at      DateTime           @default(now()) @db.Timestamptz(6)
  conversation    chat_conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at], map: "chat_messages_conversation_idx")
}

model game_embeddings {
  id         Int      @id @default(autoincrement())
  game_id    Int      @unique
  content    String
  embedding  Unsupported("vector(1536)")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  games      games    @relation(fields: [game_id], references: [id], onDelete: Cascade)
}

model player_stat_embeddings {
  id         Int      @id @default(autoincrement())
  player_id  Int
  league     String
  season     String
  embedding  Unsupported("vector(14)")
  games_used Int      @default(0)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  players    players  @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([player_id, league, season])
  @@index([league, season])
}

model player_aliases {
  id        Int     @id @default(autoincrement())
  player_id Int
  alias     String
  players   players @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([player_id, alias])
  @@index([alias(ops: raw("gin_trgm_ops"))], map: "idx_player_aliases_trgm", type: Gin)
}

model user_favorite_players {
  user_id    String   @db.Uuid
  player_id  Int
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  players    players  @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@id([user_id, player_id])
}

model user_favorite_teams {
  user_id    String   @db.Uuid
  team_id    Int
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  teams      teams    @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@id([user_id, team_id])
}

model player_awards {
  id         Int      @id @default(autoincrement())
  player_id  Int
  league     String   @db.VarChar(10)
  season     String   @db.VarChar(10)
  award_type String   @db.VarChar(50)
  award_name String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  players    players  @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([player_id, league, season, award_type], map: "player_awards_unique")
  @@index([player_id], map: "player_awards_player_idx")
  @@index([league, season], map: "player_awards_league_season_idx")
}

model plays {
  id                Int     @id @default(autoincrement())
  gameid            Int
  espn_play_id      String?
  sequence          Int
  period            Int
  clock             String?
  description       String
  short_text        String?
  home_score        Int?
  away_score        Int?
  scoring_play      Boolean @default(false)
  team_id           Int?
  play_type         String?
  drive_number      Int?
  drive_description String?
  drive_result      String?
  games             games   @relation(fields: [gameid], references: [id], onDelete: Cascade)
  teams             teams?  @relation(fields: [team_id], references: [id], onDelete: SetNull)

  @@unique([gameid, sequence])
  @@index([gameid, period])
  @@index([gameid, scoring_play])
}

