# Backend environment example
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://youruser:yourpassword@yourhost:5432/yourdb

OPENAI_API_KEY=your_openai_api_key_here

SUPABASE_SECRET_KEY=your_supabase_secret_key_here
SUPABASE_URL=your_supabase_url_here

SUPABASE_WEBHOOK_SECRET=your_supabase_webhook_secret_here

# Redis cache — set to a Redis connection string to enable caching (leave blank to disable)
REDIS_URL=redis://default:yourpassword@yourhost:6379